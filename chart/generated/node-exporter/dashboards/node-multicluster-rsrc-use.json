         "title": "CPU",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
         },
         "fieldConfig": {
            "defaults": {
               "custom": {
                  "fillOpacity": 100,
                  "showPoints": "never",
                  "stacking": {
                     "mode": "normal"
                  }
               },
               "unit": "percentunit"
            }
         },
         "gridPos": {
            "h": 7,
            "w": 12,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "options": {
            "legend": {
               "showLegend": false
            },
            "tooltip": {
               "mode": "multi",
               "sort": "desc"
            }
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "sum(\n  ((\n    instance:node_cpu_utilisation:rate5m{job=\"node-exporter\"}\n    *\n    instance:node_num_cpu:sum{job=\"node-exporter\"}\n  ) != 0)\n  / scalar(sum(instance:node_num_cpu:sum{job=\"node-exporter\"}))\n) by (cluster)\n",
               "legendFormat": "{{%(clusterLabel)s}}"
            }
         ],
         "title": "CPU Utilisation",
         "type": "timeseries"
      },
      {
         "datasource": {
            "type": "prometheus",
